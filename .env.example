# NeuroEdge v2 — Environment Configuration
# Copy to .env and edit. Never commit .env to git.

APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Database — SQLite for local/edge, change to postgresql+asyncpg:// for cloud
DATABASE_URL=sqlite+aiosqlite:///./neuroedge.db

# API
API_HOST=0.0.0.0
API_PORT=8000

# IoT Simulator
IOT_NODE_COUNT=8
LORA_RANGE_KM=15.0

# Anomaly Detection
ANOMALY_WINDOW=50
ANOMALY_THRESHOLD=2.5
RELIABILITY_TARGET=0.9995

# Operator Monitoring
GAZE_EAR_THRESHOLD=0.22
FATIGUE_BLINK_RATE=25
PPG_SAMPLE_RATE_HZ=100
